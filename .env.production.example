# ========================================
# EXEMPLO DE .env PARA PRODUÇÃO
# ========================================
# Copie este arquivo e renomeie para .env
# Preencha com suas credenciais reais
# NUNCA commite este arquivo no Git!
# ========================================

# Servidor
PORT=5000
NODE_ENV=production

# Banco de Dados
DB_HOST=seu-servidor-mysql.com
DB_USER=seu_usuario
DB_PASS=sua_senha_segura
DB_NAME=contrateme_prod
DB_PORT=3306

# JWT Secret
# Gere uma chave forte: openssl rand -base64 32
JWT_SECRET=sua_chave_secreta_muito_longa_e_complexa_aqui

# Mercado Pago - PRODUÇÃO
# Obtenha em: https://www.mercadopago.com.br/developers
# Use as credenciais de PRODUÇÃO, não de teste!
MP_ACCESS_TOKEN=APP-XXXXXXXXXXXX-XXXXXX-XXXXXXXXXXXXXXXXXXXXXXXX-XXXXXXXXX

# URLs
FRONTEND_URL=https://seudominio.com
BACKEND_URL=https://api.seudominio.com

# Opcional: Sentry (monitoramento de erros)
# SENTRY_DSN=https://xxxxx@sentry.io/xxxxx
